# Copy this file to .env.local and fill in real values.
# See README.md "Checklist de configuração" for exactly where to get each one.

# --- Supabase (auth + database) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (transactional email) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# --- Polar.sh (payments / subscriptions) ---
POLAR_ACCESS_TOKEN=
POLAR_SERVER=sandbox
POLAR_SUCCESS_URL=http://localhost:3000/dashboard?checkout=success
POLAR_WEBHOOK_SECRET=
POLAR_PRODUCT_PLUS_ID=
POLAR_PRODUCT_PRO_ID=
NEXT_PUBLIC_POLAR_PRODUCT_PLUS=
NEXT_PUBLIC_POLAR_PRODUCT_PRO=

# --- Chatwoot (AI-assisted support widget) ---
NEXT_PUBLIC_CHATWOOT_BASE_URL=
NEXT_PUBLIC_CHATWOOT_WEBSITE_TOKEN=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=
